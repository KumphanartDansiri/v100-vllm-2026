From ccb6557d4f117d985a9763337a5b7e5e7ff3f375 Mon Sep 17 00:00:00 2001
From: "kumphanart.dansiri" <kumphanartd@gmail.com>
Date: Thu, 11 Jun 2026 15:04:38 +0000
Subject: [PATCH] V100 paged-KV + CUDA 12.6 fixes (vLLM integration findings)

Three fixes found integrating with vLLM 0.21 paged attention on 8x V100:

1. include/forward.h: BLOCK_N_128 160 -> 128. CORRECTNESS: with paged KV
   (page_block_size=256), a KV tile must divide the page or tile 1
   (rows 160-319) straddles the page boundary and the single-pointer linear
   load reads a foreign physical block on non-contiguous block tables.
   Real invariant: page_block_size % BLOCK_N == 0 (D=32/64/256 already
   satisfy it; D=128 with 160 and D=16 with 512 do not). Reproducer:
   interleaved block_table + garbage beyond seqused_k -> output contains
   the garbage; after this fix cos=1.000000 vs fp32 reference up to 24k.

2. include/mat_mul.h: __tanhf -> tanhf (2 sites). __tanhf is a host-only
   function before CUDA 12.8/12.9; device code fails to compile on
   nvcc 12.6. tanhf is valid everywhere (softcap path only).

3. setup.py: relax torch CUDA wheel pin 12.9 -> 12.6. With fix (2) the
   kernels build and pass tests on torch 2.11+cu126 / nvcc 12.6 (the other
   Volta-supporting torch island besides 2.10+cu129); measured perf is
   equal (109.9 vs 112.6 ms/layer @ 26k prefill, D=128 GQA 12/1).

Known remaining divergence from upstream FA2 (not fixed here): the low-level
varlen_fwd assumes dense H_Q*D query rows (only stride(-1)==1 is checked);
strided q views (e.g. fused-QKV .split()) are silently misread. Upstream FA2
passes explicit q strides. Callers must pass contiguous q (the public python
wrapper already does; direct low-level callers must densify).

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 include/forward.h | 2 +-
 include/mat_mul.h | 4 ++--
 setup.py          | 2 +-
 3 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/include/forward.h b/include/forward.h
index 914d889..e169fab 100644
--- a/include/forward.h
+++ b/include/forward.h
@@ -16,7 +16,7 @@
 #define BLOCK_N_64  128
 
 #define BLOCK_M_128 32
-#define BLOCK_N_128 160
+#define BLOCK_N_128 128
 
 #define BLOCK_M_256 32
 #define BLOCK_N_256 64
diff --git a/include/mat_mul.h b/include/mat_mul.h
index c386681..da2052c 100644
--- a/include/mat_mul.h
+++ b/include/mat_mul.h
@@ -113,7 +113,7 @@ __device__ __forceinline__ void WMMA_GEMM_SCORES(
                             val = __fmaf_rn(-ALIBI_SLOPE, fabsf(static_cast<float>(global_m - (global_n - SEQLEN_OFFSET))), val);
                         }
                         if constexpr (IS_SOFTCAP) {
-                            val = __fmul_rn(SOFTCAP, __tanhf(__fmul_rn(val, softcap_rcp)));
+                            val = __fmul_rn(SOFTCAP, tanhf(__fmul_rn(val, softcap_rcp)));
                         }
                     } else {
                         val = NEG_INF;
@@ -142,7 +142,7 @@ __device__ __forceinline__ void WMMA_GEMM_SCORES(
                         val = __fmaf_rn(-ALIBI_SLOPE, fabsf(static_cast<float>(global_m - (global_n - SEQLEN_OFFSET))), val);
                     }
                     if constexpr (IS_SOFTCAP) {
-                        val = __fmul_rn(SOFTCAP, __tanhf(__fmul_rn(val, softcap_rcp)));
+                        val = __fmul_rn(SOFTCAP, tanhf(__fmul_rn(val, softcap_rcp)));
                     }
                 } else {
                     val = NEG_INF;
diff --git a/setup.py b/setup.py
index 0358f17..955bdf5 100644
--- a/setup.py
+++ b/setup.py
@@ -138,7 +138,7 @@ def get_cmdclass():
 
             if not torch.cuda.is_available():
                 raise RuntimeError("CUDA is required but not available.")
-            if parse(torch.version.cuda) < parse("12.9"):
+            if parse(torch.version.cuda) < parse("12.6"):
                 raise RuntimeError(f"CUDA version {torch.version.cuda} < 12.9 is not supported.")
 
             super().build_extensions()
